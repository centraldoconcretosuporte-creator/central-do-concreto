      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(git reset --soft:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run start)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
